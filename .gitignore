# 依赖
node_modules/
.pnpm-store/

# 构建产物
dist/
build/
out/
*.tsbuildinfo

# Turbo
.turbo/

# 环境变量（永不入库）
.env
.env.local
.env.*.local
!.env.example
!*/.env.example

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 测试与覆盖率
coverage/
.nyc_output/

# Prisma 生成产物（按 ARCHITECTURE 决策，client 输出到 packages/db/src/generated）
packages/db/src/generated/

# React Native / Metro
.metro/
.metro-health-check*
metro.log

# Android 构建产物
apps/mobile/android/.gradle/
apps/mobile/android/build/
apps/mobile/android/app/build/
apps/mobile/android/captures/
apps/mobile/android/local.properties
apps/mobile/android/*.iml
apps/mobile/android/app/*.iml

# iOS（仅保留代码兼容，不构建）
apps/mobile/ios/Pods/
apps/mobile/ios/build/
apps/mobile/ios/DerivedData/
apps/mobile/ios/*.xcworkspace
apps/mobile/ios/*.xcuserdatad/

# 编辑器与系统
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
.DS_Store
Thumbs.db

# Docker 卷数据（如果本机 mount 到仓库内）
docker/volumes/

# 临时文件
*.tmp
*.bak
*.swp
