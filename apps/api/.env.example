# =============================================================================
# Fitness AI Assistant · apps/api 环境变量（M2 NestJS）
# =============================================================================
# 推荐：继续在仓库根目录维护一份 `.env`，并在启动 API 时设置 `NODE_OPTIONS` 或通过
# `dotenv` 继承；也可用 PowerShell：
#   copy ..\.env .env
#
# Nest `ConfigModule` 与 Prisma `@fitness/db` 都从进程环境读取这些键名（大写）。
# =============================================================================

NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://fitness:fitness@127.0.0.1:5432/fitness?schema=public

REDIS_URL=redis://127.0.0.1:6379
# Windows 下勿用 localhost（会走 IPv6，Docker 端口映射连不上）

JWT_ACCESS_SECRET=please-change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=please-change-me-refresh-secret-min-32-chars-long

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345678
S3_BUCKET=media
S3_FORCE_PATH_STYLE=true

# MinIO init 创建的 bucket：`media`。
# Android 模拟器联调（Qwen 拉图 + 预签名展示）：S3_PUBLIC_ENDPOINT=http://10.0.2.2:9000
# 真机局域网：S3_PUBLIC_ENDPOINT=http://192.168.x.x:9000
# S3_PUBLIC_ENDPOINT=http://10.0.2.2:9000

# --- Coach Agent（M5 LangGraph ReAct；默认 false 仍走 runCoachChatStream）---
# COACH_AGENT_ENABLED=false

# --- AI API（M3 使用；本地可不填，相关 worker 会把任务标为 FAILED）---
# DeepSeek（OpenAI 兼容）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 阿里云 DashScope（Qwen-VL）
# DASHSCOPE_API_KEY=
