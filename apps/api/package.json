{
  "name": "@fitness/api",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS 模块化单体（HTTP + Worker + Cron 三入口，M2 实装）",
  "license": "UNLICENSED",
  "scripts": {
    "build": "rimraf dist tsconfig.build.tsbuildinfo tsconfig.tsbuildinfo && nest build",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "clean": "rimraf dist .turbo",
    "prestart:api": "node ../../scripts/ensure-workspace-deps.mjs",
    "start:api": "nest start --watch",
    "prestart:worker": "node ../../scripts/ensure-workspace-deps.mjs",
    "start:worker": "nest start --watch --entryFile worker",
    "prestart:cron": "node ../../scripts/ensure-workspace-deps.mjs",
    "start:cron": "nest start --watch --entryFile schedule"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.731.1",
    "@aws-sdk/s3-request-presigner": "^3.731.1",
    "@fitness/ai-core": "workspace:*",
    "@fitness/db": "workspace:*",
    "@fitness/shared": "workspace:*",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^8.0.7",
    "@prisma/client": "^5.22.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.39.5",
    "dotenv": "^17.4.2",
    "ioredis": "^5.4.2",
    "joi": "^17.13.3",
    "nestjs-pino": "^4.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "~3.23.8"
  },
  "devDependencies": {
    "@fitness/config": "workspace:*",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "~5.5.4"
  }
}
