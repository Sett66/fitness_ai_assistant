{
  "name": "@fitness/db",
  "version": "0.0.0",
  "private": true,
  "description": "Prisma schema / 单例 client / seed —— PostgreSQL 数据访问层",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "node scripts/clean-dist-artifacts.mjs && tsc -p tsconfig.build.json && node scripts/copy-generated.mjs",
    "prisma": "prisma",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset --skip-seed",
    "studio": "prisma studio --port 5557 --browser none",
    "format:schema": "prisma format",
    "seed": "tsx prisma/seed.ts",
    "verify:seed": "node scripts/verify-seed.mjs",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"@fitness/db: 暂无测试\" && exit 0",
    "clean": "rimraf dist .turbo"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@fitness/config": "workspace:*",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prisma": "^5.22.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "~5.5.4"
  }
}
