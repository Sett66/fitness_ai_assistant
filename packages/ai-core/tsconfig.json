{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@fitness/config/tsconfig.node.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@fitness/shared": ["../shared/dist/index.d.ts"],
      "@fitness/shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", ".turbo"]
}
