# 默认行尾归一化为 LF，避免 Windows CRLF 串味
* text=auto eol=lf

# Windows 专属脚本保持 CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# 二进制不做转换
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.jar   binary
*.keystore binary

# 锁文件保持原状，便于 review
pnpm-lock.yaml -diff
