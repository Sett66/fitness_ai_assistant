# =============================================================================
# Fitness AI Assistant · 环境变量模板
# =============================================================================
# 用法（Windows PowerShell，在仓库根目录）：
#   copy .env.example .env
#   copy .env.example packages\db\.env
# 然后按需修改密钥；不要把真实密钥提交到 git。
# =============================================================================

# --- Node / 通用 ---
NODE_ENV=development

# --- PostgreSQL（与 docker/docker-compose.yml 默认一致）---
POSTGRES_USER=fitness
POSTGRES_PASSWORD=fitness
POSTGRES_DB=fitness
POSTGRES_PORT=5432

# Prisma / NestJS 共用（宿主机访问容器内的 postgres，host 用 localhost）
# Windows 下部分环境 localhost 会优先走 IPv6，Prisma 连不上时用 127.0.0.1
DATABASE_URL=postgresql://fitness:fitness@127.0.0.1:5432/fitness?schema=public

# --- Redis（BullMQ + 可选缓存）---
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379

# --- MinIO（S3 兼容，本地对象存储）---
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345678
# init 容器创建的 bucket 名（ARCH §6 presigned 上传目标）
MINIO_BUCKET=media

# 应用内 S3 兼容客户端配置（M2 apps/api 实装 StorageProvider 时使用）
# 宿主机开发时 endpoint 指向 localhost；容器内访问时为 http://minio:9000
# Windows 下 localhost 可能走 IPv6 导致连不上；与 DATABASE_URL 一致用 127.0.0.1
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345678
S3_BUCKET=media
S3_FORCE_PATH_STYLE=true
# 预签名 URL 返回给手机端时，若手机在真机需填电脑局域网 IP，否则可留空用默认值
# S3_PUBLIC_ENDPOINT=http://192.168.x.x:9000

# --- JWT（M2 auth 使用；以下为占位，生产必须换成强随机串）---
JWT_ACCESS_SECRET=please-change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=please-change-me-refresh-secret-min-32-chars-long

# --- Coach Agent（M5；默认关闭，与 M4 行为一致）---
# COACH_AGENT_ENABLED=false

# --- AI API（M3 使用；本地可不填，相关 worker 会失败直到配置）---
# DeepSeek（OpenAI 兼容）
DEEPSEEK_API_KEY= sk-47245fec86e2417d8064bd33f81f6b5c
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 阿里云 DashScope（Qwen-VL）
DASHSCOPE_API_KEY= sk-c42bb92ee70544929971c4b89f980b76
